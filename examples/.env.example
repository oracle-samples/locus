# Locus notebook configuration. Copy to .env and edit.
#
# Locus auto-detects Oracle Cloud Infrastructure (OCI) Generative AI when
# a profile is available, and falls back to the bundled mock model when
# one isn't. You don't have to set LOCUS_MODEL_PROVIDER at all if:
#   - you have ~/.oci/config (you'll run against live OCI), or
#   - you have no creds (you'll run against mock).
#
# Set it explicitly when you want to force a specific provider.

# Model provider: "oci" (default), "mock", "openai", or "anthropic".
# LOCUS_MODEL_PROVIDER=oci

# ─── OCI Generative AI (default) ────────────────────────────────────
#
# Locus picks the right transport automatically:
#   - cohere.command-r-*   → OCIModel (OCI SDK, /20231130/actions/v1)
#   - everything else      → OCIOpenAIModel (OpenAI-compatible /openai/v1)
# Set LOCUS_OCI_TRANSPORT=v1 or sdk to override. See
# docs/how-to/oci-models.md for the full story.
#
# OpenAI / Meta / xAI / Mistral / Gemini families (default transport):
# LOCUS_MODEL_PROVIDER=oci
# LOCUS_MODEL_ID=openai.gpt-4.1
# LOCUS_OCI_PROFILE=DEFAULT
# LOCUS_OCI_REGION=us-chicago-1

# Cohere R-series (uses the OCI SDK transport):
# LOCUS_MODEL_PROVIDER=oci
# LOCUS_MODEL_ID=cohere.command-r-plus-08-2024
# LOCUS_OCI_PROFILE=DEFAULT
# LOCUS_OCI_AUTH_TYPE=api_key
# LOCUS_OCI_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com

# Workload identity on OCI compute / OKE / Functions:
# LOCUS_MODEL_PROVIDER=oci
# LOCUS_MODEL_ID=openai.gpt-4.1
# LOCUS_OCI_AUTH_TYPE=instance_principal           # or resource_principal
# LOCUS_OCI_COMPARTMENT=ocid1.compartment.oc1...   # required for principal auth

# ─── Mock (offline, no credentials) ─────────────────────────────────
# Force the bundled mock model — useful in CI or air-gapped runs.
# LOCUS_MODEL_PROVIDER=mock

# ─── OpenAI ─────────────────────────────────────────────────────────
# LOCUS_MODEL_PROVIDER=openai
# LOCUS_MODEL_ID=gpt-4o
# OPENAI_API_KEY=sk-...

# ─── Anthropic ──────────────────────────────────────────────────────
# LOCUS_MODEL_PROVIDER=anthropic
# LOCUS_MODEL_ID=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-...
