# Copy to .env and source it before booting services.
# Defaults to MockModel — no creds needed to run the demo.

# Provider: mock | oci | openai
LOCUS_MODEL_PROVIDER=mock

# OCI Generative AI (when LOCUS_MODEL_PROVIDER=oci)
# LOCUS_MODEL_ID=openai.gpt-5.5-2026-04-23
# LOCUS_OCI_PROFILE=DEFAULT
# LOCUS_OCI_AUTH_TYPE=api_key
# LOCUS_OCI_REGION=us-chicago-1
# LOCUS_OCI_COMPARTMENT=ocid1.compartment.oc1..xxxxx

# OpenAI (when LOCUS_MODEL_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# LOCUS_MODEL_ID=gpt-5.5-2026-04-23

# Service ports (defaults shown)
RESEARCH_PORT=8001
FINANCE_PORT=8002
